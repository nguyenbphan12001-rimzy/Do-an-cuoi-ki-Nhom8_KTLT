    <property name="styleSheet">
     <string notr="true">/* Trạng thái bình thường */
QPushButton {
    color: #0f433d;
    background-color: #f6f6e9;
    font: 22pt &quot;MS Shell Dlg 2&quot;;
    border-radius: 20px;
    border: 3px solid #0f433d;
}

/* Khi rê chuột vào (Hover) - Vàng trầm nhưng nhạt và dịu hơn */
QPushButton:hover {
    background-color: #e0c975; 
    color: #0f433d;
}

/* Khi click chuột (Pressed) - Đậm hơn lúc hover một xíu + lún nút */
QPushButton:pressed {
    background-color: #ccb258; 
    padding-top: 4px;
    padding-left: 4px;
}</string>
