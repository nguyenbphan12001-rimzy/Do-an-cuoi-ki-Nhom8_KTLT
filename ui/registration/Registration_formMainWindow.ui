           <property name="styleSheet">
            <string notr="true">QPushButton {
    /* Màu kem bạn yêu cầu (lấy từ ảnh) */
    background-color: #f5f5dc; 
    
    /* Bo tròn góc - chỉnh số này cho khớp với khung sau */
    border-radius: 25px; 
    
    /* Viền nút (có thể để 'none' nếu muốn nút phẳng lì) */
    border: 1px solid #dcdcdc; 
    
    /* Chỉnh lề và font chữ nếu cần */
    padding: 5px;
    font-family: &quot;Segoe UI&quot;;
    color: #333333;
}

/* Hiệu ứng khi di chuột vào cho đỡ bị đơ */
QPushButton:hover {
    background-color: #efefd0; /* Tối hơn một chút khi hover */
}

/* Hiệu ứng khi click chuột */
QPushButton:pressed {
    background-color: #e5e5c0;
}</string>
