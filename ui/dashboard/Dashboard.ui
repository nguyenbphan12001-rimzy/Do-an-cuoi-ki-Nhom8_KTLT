            <property name="styleSheet">
             <string notr="true">/* Trạng thái bình thường (Giữ nguyên 100% của mày) */
QPushButton {
    color: #f6f6e9;
    background-color: #0f433d;
    font: 87 20pt &quot;Noto Sans HK Black&quot;;
    border-radius: 30px;
    border: 3px solid #58827d;
}

/* Trạng thái khi rê chuột vào (Hover) */
QPushButton:hover {
    background-color: #1a6b61; /* Màu xanh sáng hơn một chút để nổi bật */
    border: 3px solid #73a6a0; /* Viền cũng sáng lên một chút cho đồng bộ */
}

/* Thêm luôn trạng thái khi click (bấm xuống) cho nó xịn */
QPushButton:pressed {
    background-color: #0a2e2a; /* Nền tối đi khi bấm */
    border: 3px solid #3d5e5b; /* Viền tối đi */
}</string>
