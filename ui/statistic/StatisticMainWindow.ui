     <string notr="true">
QPushButton{color: rgb(255, 255, 255);
font: 87 15pt &quot;Noto Sans HK Black&quot;;
background-color: rgb(24, 78, 73);
border-radius: 15px;
border: 3px solid  #58827d;
font-weight: Bold}

/* Trạng thái khi rê chuột vào (Hover) - Đảo màu cho xịn */
QPushButton:hover {
    background-color: #1a6b61; /* Nền biến thành xanh đậm */
    color: #f6f6e9; /* Chữ sáng lên */
    /* Viền giữ nguyên màu xanh đậm nên tao không cần viết lại ở đây */
}

/* Trạng thái khi click chuột bấm xuống (Pressed) */
QPushButton:pressed {
    background-color: #0a2e2a; /* Nền tối hơn một tông so với lúc hover */
    border: 3px solid #0a2e2a; /* Viền cũng tối theo */
    color: #f6f6e9;
}</string>
