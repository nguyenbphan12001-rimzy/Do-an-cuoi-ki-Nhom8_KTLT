       <property name="styleSheet">
        <string notr="true">/* Trạng thái bình thường (Base gốc của mày) */
QComboBox {
    background-color: rgb(165, 185, 172);
    color: rgb(255, 255, 255);
    border-radius: 15px; /* Đã sửa 15p thành 15px nhé */
    border: 3px solid #58827d;
    padding-left: 10px; /* Thêm nhẹ cái này cho chữ nó không bị dính vào viền trái */
}

/* Trạng thái khi rê chuột vào (Hover) y chang mày yêu cầu */
QComboBox:hover {
    background-color: #1a6b61; /* Màu xanh sáng hơn */
    border: 3px solid #73a6a0; /* Viền sáng lên */
}

/* Trạng thái khi click vào và lúc danh sách đang xổ xuống (Pressed / On) */
QComboBox:pressed, QComboBox:on {
    background-color: #124d45; /* Nền tối đi một tông so với hover khi mày bấm xổ xuống */
    border: 3px solid #3d5e5b; /* Viền cũng chìm màu xuống */
}</string>
