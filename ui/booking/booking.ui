         <property name="styleSheet">
          <string notr="true">/* Trạng thái bình thường (Code gốc của mày) */
QRadioButton {
    background-color: rgb(203, 221, 209);
    border-radius: 15px;
    border: 3px solid #58827d;
    padding: 5px; /* Tao thêm nhẹ 5px padding để chữ không bị dính sát vào cái viền bo góc */
}

/* Trạng thái khi rê chuột vào (Hover) */
QRadioButton:hover {
    background-color: #1a6b61; /* Màu xanh sáng hơn một chút để nổi bật */
    border: 3px solid #73a6a0;/* Viền sáng lên đồng bộ với nút kia */
}

/* Trạng thái khi click chuột bấm xuống (Pressed) */
QRadioButton:pressed {
    background-color: rgb(175, 198, 183); /* Nền chìm tối xuống khi bấm */
    border: 3px solid #3d5e5b; /* Viền tối đi đồng bộ với nút kia */
}</string>
