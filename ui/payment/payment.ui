             <property name="styleSheet">
              <string notr="true">/* Trạng thái bình thường */
QCheckBox {
    spacing: 15px;      /* Khoảng cách giữa ô check và chữ */
    padding: 10px;      /* Tạo khoảng trống bên trong thẻ */
    background-color: #f9f9f9;
    border: 2px solid #e0e0e0;
    border-radius: 10px;
}

/* Khi di chuột qua (Hover) */
QCheckBox:hover {
    border-color: #143d3a;
    background-color: #f0f7f6;
}

/* Khi được TÍCH CHỌN (Quan trọng nhất) */
QCheckBox:checked {
    border: 2px solid #143d3a;
    background-color: #e8f2f1;
}

/* Ẩn cái ô vuông mặc định đi để nhìn cho sạch (Tùy chọn) */
QCheckBox::indicator {
    width: 18px;
    height: 18px;
}</string>
