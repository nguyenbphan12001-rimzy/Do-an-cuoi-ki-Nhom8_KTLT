             <property name="styleSheet">
              <string notr="true">/* 1. Trạng thái bình thường */
QRadioButton {
    padding: 10px 25px;
    border-radius: 18px;
    border: 2px solid #d1d1d1;
    background-color: white;
    color: #333;
    font-weight: bold;
}

/* 2. Khi rê chuột vào (Hover) */
QRadioButton:hover {
    background-color: #f0fdfa;
    border-color: #143d3a;
}

/* 3. Khi được chọn (Checked) */
QRadioButton:checked {
    color: white;
    background-color: #143d3a;
    border-color: #143d3a;
}

/* 4. Ẩn cái chấm tròn mặc định */
QRadioButton::indicator {
    width: 0px;
}</string>
