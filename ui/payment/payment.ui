             <property name="styleSheet">
              <string notr="true">QPushButton {
    background-color: #143d3a;    
    color: white;                 
    /* CÀI ĐẶT BO TRÒN Ở ĐÂY */
    border-radius: 20px;          /* Số này càng lớn thì càng tròn */
    border: 2px solid #143d3a;    /* Thêm viền để định hình rõ hơn */
    
    font-weight: bold;
    font-size: 18px;              /* Chỉnh cho chữ to lên như bạn muốn */
    padding: 10px;                /* Tạo khoảng trống cho chữ thở */
}

/* Hiệu ứng khi rê chuột */
QPushButton:hover {
    background-color: #1a524e;
    border-color: #1a524e;
}

/* Hiệu ứng khi nhấn (lún xuống) */
QPushButton:pressed {
    background-color: #0d2927;
    padding-top: 12px; 
}</string>
